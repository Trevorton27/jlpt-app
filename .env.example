# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jlpt_app?schema=public"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ElevenLabs — users bring their own API key via /settings. No server fallback.
# Agent ID is still a shared env var for the Convai signed-url flow.
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id

# Encryption key for user-supplied secrets (ElevenLabs BYOK, etc.)
# Must decode to exactly 32 bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
USER_SECRET_ENCRYPTION_KEY=

# JLPT Vocab API
NEXT_PUBLIC_JLPT_API_URL=https://jlpt-vocab-api.vercel.app
